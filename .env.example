# ─── Archivo Atlas — Variables de entorno ──────────────────────────────────
#
# Copia este archivo como .env.local y completa tus valores reales.
# .env.local está en .gitignore — NUNCA subas tokens al repositorio.

# ─── Mapbox ─────────────────────────────────────────────────────────────────
# Obtén tu token en: https://account.mapbox.com
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiTVVUVUFMSURBRCIsImEiOiJFWEFNUExFIn0.XXXXXXXX

# ─── Uwazi ──────────────────────────────────────────────────────────────────
# En desarrollo deja 'mock' para usar datos de prueba locales.
# En producción apunta a tu instancia real.
#
# VITE_UWAZI_URL=https://tu-instancia.uwazi.io
# VITE_UWAZI_TOKEN=tu-jwt-token-aqui
#
# Para obtener el token JWT de Uwazi:
#   POST /api/login { username, password }
#   → responde con { token: "..." }
#   Úsalo en header: Authorization: Bearer <token>

VITE_UWAZI_URL=mock
VITE_UWAZI_TOKEN=
# ID del template "Evento" en Uwazi (Settings → Templates)
# VITE_UWAZI_TEMPLATE_EVENTO=507f1f77bcf86cd799439011

# CDN de rhino3dm para el visor .3dm (opcional)
# VITE_RHINO3DM_CDN=https://unpkg.com/rhino3dm@8.0.1/

# ─── Supabase (escenas 3D colaborativas) ────────────────────────────────────
# Opcional en dev: sin esto, anotaciones y modelos usan localStorage.
# VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
# VITE_SUPABASE_ANON_KEY=tu-anon-key
